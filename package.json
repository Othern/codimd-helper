{
  "name": "codimd-helper",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "codimd-helper": "./dist/index.js"
  },
  "scripts": {
    "prebuild": "node scripts/check-node-version.cjs",
    "dev": "tsx src/index.ts",
    "build": "node ./node_modules/typescript/bin/tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "install:server-wrapper": "bash scripts/install-server-wrapper.sh",
    "test": "vitest run"
  },
  "dependencies": {
    "commander": "^14.0.0",
    "dotenv": "^16.4.7",
    "pg": "^8.16.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/pg": "^8.15.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
